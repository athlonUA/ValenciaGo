{
  "name": "valencia-events",
  "version": "0.1.0",
  "private": true,
  "description": "Event discovery platform for Valencia, Spain",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "migrate": "node-pg-migrate up --migration-file-language sql --migrations-dir migrations",
    "migrate:create": "node-pg-migrate create --migration-file-language sql --migrations-dir migrations",
    "ingest": "tsx src/cli/ingest.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "migrate:down": "node-pg-migrate down --migration-file-language sql --migrations-dir migrations"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "grammy": "^1.30.0",
    "node-cron": "^3.0.3",
    "node-pg-migrate": "^7.7.0",
    "openai": "^6.33.0",
    "pg": "^8.13.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.0"
  }
}
