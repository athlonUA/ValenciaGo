# Database (required — DB_PASSWORD must be set for docker-compose)
DATABASE_URL=postgres://events:events_dev@localhost:5432/valencia_events
DB_PASSWORD=events_dev             # Change this! Required by docker-compose.
DB_PORT=5432

# Telegram Bot (required — get token from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Bot admin (optional — your Telegram numeric user ID, enables voice search)
BOT_OWNER_ID=

# Source Adapters
EVENTBRITE_TOKEN=              # Optional: Eventbrite API token for richer data

# AI Features (optional — enables smart search and event summaries)
OPENAI_API_KEY=

# Ingestion
INGESTION_CRON=0 */6 * * *    # Every 6 hours
INGESTION_ENABLED=true

# App
NODE_ENV=development
LOG_LEVEL=info
